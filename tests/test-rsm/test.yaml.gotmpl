# code: language=yaml
# yaml-language-server: $schema=../../.up/json/models/test.schema.json

# Write your tests under items. No template input is provided. You can use any
# builtin Go templating features plus functions from Sprig:
# https://masterminds.github.io/sprig/

items:
- apiVersion: meta.dev.upbound.io/v1alpha1
  kind: CompositionTest
  metadata:
    name: "rsm"
  spec:
    compositionPath: "apis/resourcestatemetrics/composition.yaml"
    xrPath: "examples/xr-rsm.yaml"
    xrdPath: "apis/resourcestatemetrics/definition.yaml"
    timeoutSeconds: 60
    validate: false
    assertResources:
      - apiVersion: apiextensions.k8s.io/v1
        kind: CustomResourceDefinition
        metadata:
          annotations:
            controller-gen.kubebuilder.io/version: v0.16.5
            crossplane.io/composition-resource-name: crd
          labels:
            crossplane.io/composite: rsm
          name: resourcemetricsmonitors.resource-state-metrics.instrumentation.k8s-sigs.io
        spec:
          group: resource-state-metrics.instrumentation.k8s-sigs.io
          names:
            kind: ResourceMetricsMonitor
            listKind: ResourceMetricsMonitorList
            plural: resourcemetricsmonitors
            shortNames:
            - rmm
            singular: resourcemetricsmonitor
          scope: Namespaced
          versions:
          - name: v1alpha1
            schema:
              openAPIV3Schema:
                description: ResourceMetricsMonitor is a specification for a ResourceMetricsMonitor
                  resource.
                properties:
                  apiVersion:
                    description: |-
                      APIVersion defines the versioned schema of this representation of an object.
                      Servers should convert recognized schemas to the latest internal value, and
                      may reject unrecognized values.
                      More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#resources
                    type: string
                  kind:
                    description: |-
                      Kind is a string value representing the REST resource this object represents.
                      Servers may infer this from the endpoint the client submits requests to.
                      Cannot be updated.
                      In CamelCase.
                      More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#types-kinds
                    type: string
                  metadata:
                    type: object
                  spec:
                    description: ResourceMetricsMonitorSpec is the spec for a ResourceMetricsMonitor
                      resource.
                    properties:
                      configuration:
                        description: Configuration is the RSM configuration that generates
                          metrics.
                        properties:
                          cardinalityLimit:
                            description: CardinalityLimit sets the maximum total cardinality
                              for this RMM (0 means use global default).
                            format: int64
                            minimum: 0
                            type: integer
                          stores:
                            description: Stores defines the resources to watch and the metrics
                              to generate.
                            items:
                              description: |-
                                Store defines how to generate metrics for a specific resource type.
                                GVK fields support wildcards ("*") to match multiple resources via API discovery.
                                When using wildcards, the controller will auto-discover matching resources.
                              properties:
                                cardinalityLimit:
                                  description: CardinalityLimit sets the maximum cardinality
                                    for this store (0 means use default).
                                  format: int64
                                  minimum: 0
                                  type: integer
                                families:
                                  description: Families defines the metric families to generate
                                    for this resource.
                                  items:
                                    description: Family represents a metric family (a group
                                      of metrics with the same name).
                                    properties:
                                      cardinalityLimit:
                                        description: CardinalityLimit sets the maximum cardinality
                                          for this family (0 means unlimited).
                                        format: int64
                                        minimum: 0
                                        type: integer
                                      help:
                                        description: Help is the help text for this metric
                                          family.
                                        minLength: 1
                                        type: string
                                      labels:
                                        description: Labels defines additional labels to apply
                                          to all metrics in this family.
                                        items:
                                          description: Label directly associates a label name
                                            with its value expression.
                                          properties:
                                            name:
                                              description: Name is the label name.
                                              maxLength: 128
                                              minLength: 1
                                              type: string
                                            value:
                                              description: Value is the expression to evaluate
                                                for this label's value.
                                              minLength: 1
                                              type: string
                                          required:
                                          - name
                                          - value
                                          type: object
                                        type: array
                                      metrics:
                                        description: |-
                                          Metrics defines the individual metrics within this family.
                                          When Starlark is set, this field is ignored.
                                        items:
                                          description: Metric represents a single time series
                                            within a family.
                                          properties:
                                            labels:
                                              description: Labels defines the label set for
                                                this metric.
                                              items:
                                                description: Label directly associates a label
                                                  name with its value expression.
                                                properties:
                                                  name:
                                                    description: Name is the label name.
                                                    maxLength: 128
                                                    minLength: 1
                                                    type: string
                                                  value:
                                                    description: Value is the expression to
                                                      evaluate for this label's value.
                                                    minLength: 1
                                                    type: string
                                                required:
                                                - name
                                                - value
                                                type: object
                                              type: array
                                            resolver:
                                              description: Resolver overrides the family/store
                                                resolver for this metric.
                                              enum:
                                              - cel
                                              - unstructured
                                              - starlark
                                              - ""
                                              type: string
                                            value:
                                              description: Value is the expression to evaluate
                                                for the metric value.
                                              type: string
                                          required:
                                          - value
                                          type: object
                                        type: array
                                      name:
                                        description: Name is the metric family name (will
                                          be prefixed with kube_customresource_).
                                        maxLength: 128
                                        minLength: 1
                                        pattern: ^[a-zA-Z_][a-zA-Z0-9_]*$
                                        type: string
                                      resolver:
                                        description: Resolver overrides the store resolver
                                          for this family.
                                        enum:
                                        - cel
                                        - unstructured
                                        - starlark
                                        - ""
                                        type: string
                                      starlark:
                                        description: |-
                                          Starlark configures Starlark script-based metric generation.
                                          When set, the script generates all samples for this family,
                                          bypassing the normal Metrics/Resolver pipeline.
                                        properties:
                                          maxSteps:
                                            description: |-
                                              MaxSteps limits the number of Starlark execution steps (default: 100000).
                                              This prevents infinite loops and runaway scripts.
                                            minimum: 1000
                                            type: integer
                                          script:
                                            description: |-
                                              Script is the inline Starlark script source code.
                                              The script has access to `obj` (the resource as a dict) and built-in functions:
                                              - quantity_to_float(s): Parse Kubernetes Quantity ("100m", "1Gi") to float
                                              - metric(labels, value): Create a sample with labels dict and float value
                                              - family(name, help, kind, samples): Create a family with list of samples
                                            minLength: 1
                                            type: string
                                          timeout:
                                            description: 'Timeout is the maximum execution
                                              time in seconds (default: 5, max: 60).'
                                            maximum: 60
                                            minimum: 1
                                            type: integer
                                        required:
                                        - script
                                        type: object
                                    required:
                                    - help
                                    - name
                                    type: object
                                  minItems: 1
                                  type: array
                                group:
                                  description: |-
                                    Group is the API group of the resource (empty string for core resources).
                                    Supports "*" to match all groups.
                                  type: string
                                kind:
                                  description: |-
                                    Kind is the kind of the resource.
                                    Supports "*" to match all kinds within the specified group/version.
                                  type: string
                                labels:
                                  description: Labels defines additional labels to apply to
                                    all metrics in this store.
                                  items:
                                    description: Label directly associates a label name with
                                      its value expression.
                                    properties:
                                      name:
                                        description: Name is the label name.
                                        maxLength: 128
                                        minLength: 1
                                        type: string
                                      value:
                                        description: Value is the expression to evaluate for
                                          this label's value.
                                        minLength: 1
                                        type: string
                                    required:
                                    - name
                                    - value
                                    type: object
                                  type: array
                                resolver:
                                  description: |-
                                    Resolver sets the default resolver for all families/metrics in this store.
                                    If not specified, must be set at the family or metric level.
                                  enum:
                                  - cel
                                  - unstructured
                                  - starlark
                                  - ""
                                  type: string
                                resource:
                                  description: Resource is the plural resource name (e.g.
                                    "deployments", "pods").
                                  type: string
                                selectors:
                                  description: Selectors defines how to filter the resources
                                    to watch.
                                  properties:
                                    field:
                                      description: Field is a field selector for filtering
                                        resources.
                                      type: string
                                    label:
                                      description: Label is a label selector for filtering
                                        resources.
                                      type: string
                                  type: object
                                version:
                                  description: Version is the API version of the resource.
                                    Supports "*" to match all versions.
                                  type: string
                              required:
                              - families
                              type: object
                            minItems: 1
                            type: array
                        required:
                        - stores
                        type: object
                    required:
                    - configuration
                    type: object
                  status:
                    description: ResourceMetricsMonitorStatus is the status for a ResourceMetricsMonitor
                      resource.
                    properties:
                      cardinality:
                        description: Cardinality tracks the cardinality metrics for this resource.
                        properties:
                          cutoffFamilies:
                            description: CutoffFamilies lists the families that are currently
                              cut off due to threshold violations.
                            items:
                              type: string
                            type: array
                          lastUpdated:
                            description: LastUpdated is the timestamp of the last cardinality
                              update.
                            format: date-time
                            type: string
                          perFamily:
                            additionalProperties:
                              format: int64
                              type: integer
                            description: PerFamily maps family names to their cardinality.
                            type: object
                          perStore:
                            additionalProperties:
                              format: int64
                              type: integer
                            description: PerStore maps store identifiers (group/version/kind)
                              to their cardinality.
                            type: object
                          thresholdsExceeded:
                            description: ThresholdsExceeded indicates whether any cardinality
                              threshold has been exceeded.
                            type: boolean
                          total:
                            description: Total is the total number of time series generated
                              by this RMM.
                            format: int64
                            type: integer
                        type: object
                      conditions:
                        description: Conditions is an array of conditions associated with
                          the resource.
                        items:
                          description: Condition contains details for one aspect of the current
                            state of this API Resource.
                          properties:
                            lastTransitionTime:
                              description: |-
                                lastTransitionTime is the last time the condition transitioned from one status to another.
                                This should be when the underlying condition changed.  If that is not known, then using the time when the API field changed is acceptable.
                              format: date-time
                              type: string
                            message:
                              description: |-
                                message is a human readable message indicating details about the transition.
                                This may be an empty string.
                              maxLength: 32768
                              type: string
                            observedGeneration:
                              description: |-
                                observedGeneration represents the .metadata.generation that the condition was set based upon.
                                For instance, if .metadata.generation is currently 12, but the .status.conditions[x].observedGeneration is 9, the condition is out of date
                                with respect to the current state of the instance.
                              format: int64
                              minimum: 0
                              type: integer
                            reason:
                              description: |-
                                reason contains a programmatic identifier indicating the reason for the condition's last transition.
                                Producers of specific condition types may define expected values and meanings for this field,
                                and whether the values are considered a guaranteed API.
                                The value should be a CamelCase string.
                                This field may not be empty.
                              maxLength: 1024
                              minLength: 1
                              pattern: ^[A-Za-z]([A-Za-z0-9_,:]*[A-Za-z0-9_])?$
                              type: string
                            status:
                              description: status of the condition, one of True, False, Unknown.
                              enum:
                              - "True"
                              - "False"
                              - Unknown
                              type: string
                            type:
                              description: type of condition in CamelCase or in foo.example.com/CamelCase.
                              maxLength: 316
                              pattern: ^([a-z0-9]([-a-z0-9]*[a-z0-9])?(\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*/)?(([A-Za-z0-9][-A-Za-z0-9_.]*)?[A-Za-z0-9])$
                              type: string
                          required:
                          - lastTransitionTime
                          - message
                          - reason
                          - status
                          - type
                          type: object
                        type: array
                        x-kubernetes-list-map-keys:
                        - type
                        x-kubernetes-list-type: map
                    type: object
                type: object
            served: true
            storage: true
            subresources:
              status: {}
      - apiVersion: rbac.authorization.k8s.io/v1
        kind: ClusterRole
        metadata:
          name: resource-state-metrics
          annotations:
            crossplane.io/composition-resource-name: clusterrole
          labels:
            app.kubernetes.io/component: exporter
            app.kubernetes.io/name: resource-state-metrics
            app.kubernetes.io/version: "0.0.1"
            crossplane.io/composite: rsm
          ownerReferences:
            - apiVersion: metrics.crossplane.io/v1alpha1
              blockOwnerDeletion: true
              controller: true
              kind: ResourceStateMetrics
              name: rsm
              uid: ""
        rules:
          - apiGroups:
              - apiextensions.k8s.io
            resources:
              - customresourcedefinitions
            verbs:
              - get
              - list
              - watch
          - apiGroups:
              - authentication.k8s.io
            resources:
              - tokenreviews
            verbs:
              - create
          - apiGroups:
              - authorization.k8s.io
            resources:
              - subjectaccessreviews
            verbs:
              - create
          - apiGroups:
              - resource-state-metrics.instrumentation.k8s-sigs.io
            resources:
              - resourcemetricsmonitors
              - resourcemetricsmonitors/status
            verbs:
              - "*"
          - apiGroups:
              - apiextensions.crossplane.io
            resources:
              - "*"
            verbs:
              - get
              - list
              - watch
          - apiGroups:
              - metrics.crossplane.io
            resources:
              - "*"
            verbs:
              - get
              - list
              - watch
          - apiGroups:
              - pkg.crossplane.io
            resources:
              - "*"
            verbs:
              - get
              - list
              - watch
          - apiGroups:
              - aws.platform.upbound.io
            resources:
              - "*"
            verbs:
              - get
              - list
              - watch
          - apiGroups:
              - eks.aws.m.upbound.io
            resources:
              - "*"
            verbs:
              - get
              - list
              - watch
      - apiVersion: rbac.authorization.k8s.io/v1
        kind: ClusterRoleBinding
        metadata:
          name: resource-state-metrics
          annotations:
            crossplane.io/composition-resource-name: clusterrolebinding
          labels:
            app.kubernetes.io/component: exporter
            app.kubernetes.io/name: resource-state-metrics
            app.kubernetes.io/version: "0.0.1"
            crossplane.io/composite: rsm
          ownerReferences:
            - apiVersion: metrics.crossplane.io/v1alpha1
              blockOwnerDeletion: true
              controller: true
              kind: ResourceStateMetrics
              name: rsm
              uid: ""
        roleRef:
          apiGroup: rbac.authorization.k8s.io
          kind: ClusterRole
          name: resource-state-metrics
        subjects:
          - kind: ServiceAccount
            name: resource-state-metrics
            namespace: resource-state-metrics
      - apiVersion: apps/v1
        kind: Deployment
        metadata:
          name: resource-state-metrics
          namespace: resource-state-metrics
          annotations:
            crossplane.io/composition-resource-name: deployment
          labels:
            app.kubernetes.io/component: exporter
            app.kubernetes.io/name: resource-state-metrics
            app.kubernetes.io/version: "0.0.1"
            crossplane.io/composite: rsm
          ownerReferences:
            - apiVersion: metrics.crossplane.io/v1alpha1
              blockOwnerDeletion: true
              controller: true
              kind: ResourceStateMetrics
              name: rsm
              uid: ""
        spec:
          replicas: 1
          selector:
            matchLabels:
              app.kubernetes.io/name: resource-state-metrics
          template:
            metadata:
              labels:
                app.kubernetes.io/component: exporter
                app.kubernetes.io/name: resource-state-metrics
                app.kubernetes.io/version: "0.0.1"
            spec:
              automountServiceAccountToken: true
              containers:
                - name: resource-state-metrics
                  image: "xpkg.crossplane.io/crossplane-contrib/resource-state-metrics-server:5383f7d"
                  args:
                    - "--main-host=0.0.0.0"
                    - "--main-port=9999"
                    - "--self-host=0.0.0.0"
                    - "--self-port=9998"
                  ports:
                    - containerPort: 9999
                      name: http-metrics
                    - containerPort: 9998
                      name: telemetry
                  livenessProbe:
                    httpGet:
                      path: /livez
                      port: http-metrics
                    initialDelaySeconds: 5
                    timeoutSeconds: 5
                  readinessProbe:
                    httpGet:
                      path: /readyz
                      port: telemetry
                    initialDelaySeconds: 5
                    timeoutSeconds: 5
                  resources:
                    limits:
                      cpu: "200m"
                      memory: "256Mi"
                    requests:
                      cpu: "100m"
                      memory: "128Mi"
                  securityContext:
                    allowPrivilegeEscalation: false
                    capabilities:
                      drop:
                        - ALL
                    readOnlyRootFilesystem: true
                    runAsNonRoot: true
                    runAsUser: 65534
                    seccompProfile:
                      type: RuntimeDefault
              nodeSelector:
                kubernetes.io/os: linux
              serviceAccountName: resource-state-metrics
      - apiVersion: v1
        kind: Namespace
        metadata:
          name: resource-state-metrics
          annotations:
            crossplane.io/composition-resource-name: namespace
          labels:
            app.kubernetes.io/managed-by: crossplane
            app.kubernetes.io/name: resource-state-metrics
            crossplane.io/composite: rsm
          ownerReferences:
            - apiVersion: metrics.crossplane.io/v1alpha1
              blockOwnerDeletion: true
              controller: true
              kind: ResourceStateMetrics
              name: rsm
              uid: ""
      - apiVersion: v1
        kind: Service
        metadata:
          name: resource-state-metrics
          namespace: resource-state-metrics
          annotations:
            crossplane.io/composition-resource-name: service
          labels:
            app.kubernetes.io/component: exporter
            app.kubernetes.io/name: resource-state-metrics
            app.kubernetes.io/version: "0.0.1"
            crossplane.io/composite: rsm
          ownerReferences:
            - apiVersion: metrics.crossplane.io/v1alpha1
              blockOwnerDeletion: true
              controller: true
              kind: ResourceStateMetrics
              name: rsm
              uid: ""
        spec:
          type: ClusterIP
          selector:
            app.kubernetes.io/name: resource-state-metrics
          ports:
            - name: http-metrics
              port: 9999
              targetPort: http-metrics
            - name: telemetry
              port: 9998
              targetPort: telemetry
      - apiVersion: v1
        kind: ServiceAccount
        automountServiceAccountToken: false
        metadata:
          name: resource-state-metrics
          namespace: resource-state-metrics
          annotations:
            crossplane.io/composition-resource-name: serviceaccount
          labels:
            app.kubernetes.io/component: exporter
            app.kubernetes.io/name: resource-state-metrics
            app.kubernetes.io/version: "0.0.1"
            crossplane.io/composite: rsm
          ownerReferences:
            - apiVersion: metrics.crossplane.io/v1alpha1
              blockOwnerDeletion: true
              controller: true
              kind: ResourceStateMetrics
              name: rsm
              uid: ""
